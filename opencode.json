{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "small_model": "deepseek/deepseek-v4-flash",
  "instructions": [
    "./docs/SPEC.md",
    "./AGENTS.md"
  
  ],
  "autoupdate": true,
  "provider": {
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      }
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "allow"
  }
}
