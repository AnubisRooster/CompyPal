# ─── Backend (app runtime) secrets ───────────────────────────────
# Copy to backend/.env and fill in. Never commit the real .env.

# --- Companion LLM (the companion's brain) ---
ANTHROPIC_API_KEY=

# --- Voice ---
ELEVENLABS_API_KEY=
OPENAI_API_KEY=          # Whisper STT fallback only

# --- Avatar ---
READYPLAYERME_APP_ID=
READYPLAYERME_API_KEY=

# --- Graph DB ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Auth ---
JWT_SECRET=

# --- Object / blob store (mesh, audio, image cache) ---
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── Build-time (NOT app runtime) ────────────────────────────────
# Used by OpenCode's opencode.json via {env:DEEPSEEK_API_KEY}.
# Prefer putting this in your shell profile or running
# `opencode auth login` instead of the app's .env, so it's present
# in the shell environment when OpenCode starts.
DEEPSEEK_API_KEY=
